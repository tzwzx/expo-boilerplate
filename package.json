{
  "name": "expo-boilerplate",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "EXPO_UNSTABLE_MCP_SERVER=1 expo start --dev-client",
    "ios:18": "expo run:ios --device \"iPhone 16 Pro\"",
    "ios:26": "expo run:ios --device \"iPhone 17 Pro\"",
    "android": "expo run:android",
    "clean": "rm -rf ios android && rm -rf ~/Library/Developer/Xcode/DerivedData",
    "build:dev:ios": "time bunx eas-cli build --platform ios --profile development",
    "build:preview:ios": "time bunx eas-cli build --platform ios --profile preview",
    "build:prod:ios": "time bunx eas-cli build --platform ios --profile production",
    "eas:run:ios": "bunx eas-cli build:run -p ios --latest",
    "sim:uninstall": "xcrun simctl uninstall booted com.example.expo-boilerplate",
    "prebuild:ios": "expo prebuild --clean",
    "submit:ios": "time bunx eas-cli submit --platform ios --latest",
    "expo:fix": "expo install --fix",
    "expo:check": "expo install --check",
    "expo:doctor": "expo-doctor",
    "lint": "oxfmt --check . && oxlint .",
    "fix": "oxfmt --write . && oxlint --fix .",
    "tsc": "tsgo --noEmit",
    "syncpack:lint": "syncpack lint",
    "syncpack:fix": "syncpack fix",
    "knip": "knip",
    "test:unit": "bun test --only-failures",
    "test:unit:coverage": "bun test --coverage",
    "test:e2e:web": "playwright test",
    "test:e2e:app": "time maestro test e2e/app/",
    "codesweep:check": "bunx codesweep check",
    "codesweep:fix": "bunx codesweep fix",
    "react-doctor": "bunx -y react-doctor@latest .",
    "version-manager": "bun scripts/version-manager.ts",
    "rulesync": "bunx rulesync generate",
    "postinstall": "lefthook install && bun rulesync"
  },
  "dependencies": {
    "@react-navigation/native": "7.1.33",
    "expo": "55.0.8",
    "expo-constants": "55.0.9",
    "expo-dev-client": "55.0.18",
    "expo-linking": "55.0.8",
    "expo-router": "55.0.7",
    "expo-splash-screen": "55.0.12",
    "expo-status-bar": "55.0.4",
    "expo-updates": "55.0.15",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.8.4",
    "@playwright/test": "1.58.2",
    "@testing-library/react-native": "13.3.3",
    "@types/react": "19.2.14",
    "@typescript/native-preview": "7.0.0-dev.20260322.1",
    "bun-types": "1.3.11",
    "codesweep": "github:tzwzx/codesweep",
    "expo-doctor": "1.18.13",
    "expo-mcp": "0.2.4",
    "knip": "6.0.2",
    "lefthook": "2.1.4",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "react-test-renderer": "19.2.0",
    "syncpack": "14.2.1",
    "typescript": "5.9.3",
    "ultracite": "7.3.2"
  },
  "engines": {
    "bun": "1.x",
    "node": "24.x"
  }
}
